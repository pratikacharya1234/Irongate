# AgentShield — Local Runtime Configuration
# Copy to .env and configure before running.
# DO NOT commit .env files with real secrets.

NODE_ENV=development
PORT=4000
HOST=127.0.0.1
API_PREFIX=/api/v1

# Database (local SQLite — no config needed for default)
DB_PATH=./data/agentshield.db

# Auth — GENERATE A REAL SECRET BEFORE USE
JWT_SECRET=<generate-a-64-char-random-string>
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
