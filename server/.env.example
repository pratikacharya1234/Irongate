# ============================================================
# IRONGATE — AI Agent Security Platform
# Copy to .env and configure before running
# ============================================================

NODE_ENV=development
PORT=4000
HOST=0.0.0.0
API_PREFIX=/api/v1

# Database
DB_PATH=./data/irongate.db

# Auth — CHANGE THESE IN PRODUCTION
JWT_SECRET=replace-with-64-char-random-string-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3000

# WebSocket live feed
WS_PORT=4001

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Threat engine
THREAT_AUTO_BAN_SCORE=85
THREAT_SCAN_INTERVAL_MS=5000

# Ban propagation webhook (receives POST on ban events)
BAN_WEBHOOK_URL=
BAN_WEBHOOK_SECRET=

# Redis (optional — enables pub/sub + caching)
REDIS_URL=
